class Animal{
    private String animalID;
    private String name;
    private int age;
    Animal(String animalID,String name,int age){
        this.animalID = animalID;
        this.name=name;
        this.age=age;
    }
    public void setAnimalID(){
        this.animalID=animalID;
    }
    public void setName(){
        this.name=name;
    }
    public void setAge(){
        this.age=age;
    }
    public String getAnimalID(String animalID){
        return animalID;
    }
    public String getName(String name){
        return name;
    }
    public int getAge(int age){
        return age;
    }
    void makesound(){
        System.out.println("Animal makes sounds");
    }

}
class Dog extends Animal{
    private String breed;
    Dog(String animalID,String name, String breed,int age){
        super(animalID,name,age);
        this.breed=breed;
    }
    public void setBreed(String breed) {
        this.breed = breed;
    }
    public int getBreed(int breed) {
        return breed;
    }
    void makesound(){
        System.out.println("Bark");
    }
}
class Cat extends Animal{
    private String color;
    Cat(String animalID,String name,String color,int age){
        super(animalID,name,age);
        this.color=color;
    }
    public void setColor(String color) {
        this.color = color;
    }

    public String getColor() {
        return color;
    }
    void makesound() {
        System.out.println("Meew");
    }
}
public class Main {
    public static void main(String[] args){
        Animal d1=new Dog("222","Trump","german",30);
        Animal c1=new Cat ("223","Modi","black",32);
        d1.makesound();
        c1.makesound();
    }
}
