class Animal{
    void sound(){
        System.out.println("Animal Sound");
    }
}
class Cat extends Animal {
    void sound() {
        System.out.println("Cat meows");
    }
}
class Dog extends Animal {
    void sound() {
        System.out.println("Dog barks");
    }
}
public class Main {
    public static void main(String[] args){
        Dog d1=new Dog();
        d1.sound();
        Cat c1=new Cat();
        c1.sound();
    }
}
